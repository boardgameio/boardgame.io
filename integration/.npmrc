# This is a sealed integration scaffold: it consumes a locally-packed
# tarball of boardgame.io and installs a small fixed set of dev deps
# (vitest, jsdom, @testing-library/react). Cooldown protection (inherited
# from the root .npmrc as minimum-release-age=2880) trips pnpm 10.16's
# ERR_PNPM_MISSING_TIME on packages whose npm abbreviated registry metadata
# lacks the time field, and adds no security value here because the dep
# tree is bounded by this package.json.
minimum-release-age=0
